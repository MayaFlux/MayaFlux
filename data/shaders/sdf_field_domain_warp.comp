#version 450
#extension GL_GOOGLE_include_directive : enable
#include "include/sdf_field_common.glsl"

void main()
{
    vec3 p;
    if (!sdf_get_corner(gl_GlobalInvocationID.x, p))
        return;

    float freq = uintBitsToFloat(pc._pad[0]);
    float warp_s = uintBitsToFloat(pc._pad[1]);

    float f = (freq < 0.01) ? 1.5 : freq;
    float w = (warp_s < 0.001) ? 0.4 : warp_s;

    grid[gl_GlobalInvocationID.x] =
        sdf_sphere(domain_warp(p, f, w, pc.time), vec3(0.0), 1.0);
}
